# .env — fill these in before running the pipeline

# --- GAM 360 ---
GAM_NETWORK_CODE=123456789
GAM_API_VERSION=v202602
# Path to your googleads.yaml (default: config/googleads.yaml)
GAM_CREDENTIALS_PATH=config/googleads.yaml

# --- Database ---
# Use DATABASE_URL for PostgreSQL, or leave blank to use SQLite (dev only)
DATABASE_URL=postgresql://user:password@localhost:5432/gam_revenue
# Fallback SQLite path (used when DATABASE_URL is not set)
SQLITE_PATH=database/gam_revenue.db

# --- Reports ---
REPORTS_OUTPUT_DIR=reports/output
# Set to true to print revenue values in micros (raw from API) instead of dollars
REVENUE_IN_MICROS=false

# --- MCP Server ---
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# --- Alerts (optional) ---
SLACK_WEBHOOK_URL=
# Revenue drop threshold % that triggers an alert (e.g. 20 = 20% drop)
ANOMALY_THRESHOLD_PCT=20
